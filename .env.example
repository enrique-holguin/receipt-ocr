# --- Database ---
# Used by the app and by Alembic. asyncpg driver is mandatory.
DATABASE_URL=postgresql+asyncpg://read_payments:read_payments@localhost:5432/read_payments

# --- Storage ---
# Where uploaded receipt images are persisted. Relative paths are resolved from CWD.
UPLOADS_DIR=uploads

# --- Runtime ---
# One of: dev, test, prod
ENVIRONMENT=dev

# Maximum upload size in bytes (default 10 MiB).
MAX_UPLOAD_BYTES=10485760

# --- Postgres container (docker-compose) ---
POSTGRES_USER=read_payments
POSTGRES_PASSWORD=read_payments
POSTGRES_DB=read_payments
POSTGRES_PORT=5432
